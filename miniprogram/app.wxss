/* 叁柒食绿色主题 */
@import './miniprogram_npm/weui-miniprogram/weui-wxss/dist/style/weui.wxss';

/* 主题色变量 */
page {
  --primary-color: #6FCF97;
  --primary-light: #B8E6C1;
  --primary-dark: #5AC476;
  --bg-color: #F5F9F0;
  --card-bg: #FFFFFF;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --border-color: #E8F5E9;
  --success-color: #6FCF97;
  --warning-color: #FFB74D;

  --footer-height: 10vh;
  --button-size: 16vw;
  --button-color: #6FCF97;
  --button-icon-size: 6vw;
}

page {
  background: var(--bg-color);
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  min-height: 100vh;
  overflow-x: hidden;
}

.container.white {
  background-color: var(--card-bg);
}

/* 卡片样式 */
.card {
  background: var(--card-bg);
  border-radius: 20rpx;
  margin: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(124, 179, 66, 0.1);
}

/* 按钮样式 */
button {
  background: initial;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
  color: white;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(124, 179, 66, 0.3);
}

.btn-secondary {
  background: var(--border-color);
  color: var(--primary-dark);
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
}

/* 表单样式 */
.form-group {
  width: calc(100% - 40px);
  margin: 10px 20px;
  border-radius: 20rpx;
  background: var(--card-bg);
  box-shadow: 0 4rpx 20rpx rgba(124, 179, 66, 0.08);
}

.form-group_label {
  align-self: flex-start;
  margin-top: 20px;
  margin-left: 20px;
  color: var(--text-secondary);
  font-size: 28rpx;
  font-weight: 500;
}

.form-group_label:not(:first-child) {
  margin-top: 20px;
}

.form-cell {
  padding: 30rpx;
}

.form-cell:not(:last-child) {
  border-bottom: 1rpx solid var(--border-color);
}

.form-cell.inline {
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

/* 列表项样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: var(--card-bg);
  margin: 16rpx 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(124, 179, 66, 0.08);
}

.list-item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  object-fit: cover;
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.list-item-desc {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx;
}

.empty-state-image {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 40rpx;
}

.empty-state-text {
  font-size: 28rpx;
  color: var(--text-hint);
  text-align: center;
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(124, 179, 66, 0.4);
  z-index: 999;
}

.fab-icon {
  width: 50rpx;
  height: 50rpx;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.tag-green {
  background: var(--border-color);
  color: var(--primary-dark);
}

.tag-orange {
  background: #FFF3E0;
  color: #F57C00;
}

/* 动画 */
@keyframes animation-blur {
  from { filter: blur(7px); }
  to { filter: blur(0px); }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-fadeIn {
  animation: fadeIn 0.3s ease-out;
}

/* 叁柒食装饰元素 */
.pochacco-decoration {
  position: absolute;
  opacity: 0.1;
  pointer-events: none;
}

/* slideview 按钮样式 */
.weui-slideview__btn__wrp.mark-btn {
  background-color: #FFB74D !important;
}

.weui-slideview__btn__wrp.mark-btn .weui-slideview__btn {
  background-color: #FFB74D !important;
}

.weui-slideview__btn__wrp.delete-btn {
  background-color: #E57373 !important;
}

.weui-slideview__btn__wrp.delete-btn .weui-slideview__btn {
  background-color: #E57373 !important;
}

/* 非阻断式顶部提醒横条 */
.guard-banner {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx;
  z-index: 999;
  font-size: 26rpx;
}

.guard-banner.profile {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.guard-banner.bind {
  background: linear-gradient(135deg, #FFE0EC 0%, #FFCDD2 100%);
}

.guard-banner-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.guard-banner-text {
  flex: 1;
  color: #333;
  font-weight: 500;
}

.guard-banner-btn {
  padding: 8rpx 28rpx;
  background: linear-gradient(135deg, #6FCF97 0%, #5AC476 100%);
  border-radius: 30rpx;
  font-size: 24rpx;
  color: white;
  font-weight: 500;
}
