/* 蜜桃奶油系 - 轻甜情侣风主题 */
@import './theme.wxss';
@import './miniprogram_npm/weui-miniprogram/weui-wxss/dist/style/weui.wxss';

page {
  background: var(--bg-color);
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  min-height: 100vh;
  overflow-x: hidden;
}

.container.white {
  background-color: var(--card-bg);
}

/* ---- 卡片 ---- */
.card {
  background: var(--card-bg);
  border-radius: 20rpx;
  margin: 20rpx;
  padding: 30rpx;
  box-shadow: var(--shadow-card);
}

/* ---- 按钮重置 ---- */
button {
  background: initial;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

/* 主按钮 */
.btn-primary {
  background: var(--gradient-primary);
  color: white;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: var(--shadow-button);
}

/* 次要按钮 */
.btn-secondary {
  background: var(--border-color);
  color: var(--primary-color);
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
}

/* ---- 表单 ---- */
.form-group {
  width: calc(100% - 40px);
  margin: 10px 20px;
  border-radius: 20rpx;
  background: var(--card-bg);
  box-shadow: var(--shadow-card-light);
}

.form-group_label {
  align-self: flex-start;
  margin-top: 20px;
  margin-left: 20px;
  color: var(--text-secondary);
  font-size: 28rpx;
  font-weight: 500;
}

.form-group_label:not(:first-child) {
  margin-top: 20px;
}

.form-cell {
  padding: 30rpx;
}

.form-cell:not(:last-child) {
  border-bottom: 1rpx solid var(--border-color);
}

.form-cell.inline {
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

/* ---- 列表项 ---- */
.list-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: var(--card-bg);
  margin: 16rpx 24rpx;
  border-radius: 20rpx;
  box-shadow: var(--shadow-card-light);
}

.list-item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  object-fit: cover;
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.list-item-desc {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* ---- 空状态 ---- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx;
}

.empty-state-image {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 40rpx;
}

.empty-state-text {
  font-size: 28rpx;
  color: var(--text-hint);
  text-align: center;
}

/* ---- FAB 悬浮按钮 ---- */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: var(--gradient-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-fab);
  z-index: 999;
}

.fab-icon {
  width: 50rpx;
  height: 50rpx;
}

/* ---- 标签 ---- */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.tag-green {
  background: var(--border-color);
  color: var(--primary-color);
}

.tag-orange {
  background: #FFF3E0;
  color: #F57C00;
}

/* ---- 动画 ---- */
@keyframes animation-blur {
  from { filter: blur(7px); }
  to { filter: blur(0px); }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-fadeIn {
  animation: fadeIn 0.3s ease-out;
}

/* ---- 装饰 ---- */
.pochacco-decoration {
  position: absolute;
  opacity: 0.1;
  pointer-events: none;
}

/* ---- Slideview 按钮 ---- */
.weui-slideview__btn__wrp.mark-btn {
  background-color: #FFB74D !important;
}

.weui-slideview__btn__wrp.mark-btn .weui-slideview__btn {
  background-color: #FFB74D !important;
}

.weui-slideview__btn__wrp.delete-btn {
  background-color: #E57373 !important;
}

.weui-slideview__btn__wrp.delete-btn .weui-slideview__btn {
  background-color: #E57373 !important;
}


