/* ========================================
   bind-guard 组件样式 —— 极简通知横幅
   蜜桃奶油系轻甜情侣风格
   ======================================== */

/* ---- 容器 ---- */
.guard-notify {
  position: fixed;
  top: 16rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 1000;
  display: flex;
  align-items: center;
  padding: 16rpx 16rpx 16rpx 12rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  box-shadow: 0 4rpx 24rpx rgba(255, 122, 158, 0.15), 0 1rpx 4rpx rgba(255, 122, 158, 0.08);
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  transform: translateY(0);
  opacity: 1;
}

/* bind 类型微调色彩 */
.guard-notify--bind {
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 4rpx 24rpx rgba(255, 122, 158, 0.12), 0 1rpx 4rpx rgba(255, 122, 158, 0.06);
}

/* 隐藏态 */
.guard-notify--hidden {
  transform: translateY(-120rpx);
  opacity: 0;
  pointer-events: none;
}

/* ---- 左侧图标 ---- */
.guard-notify__icon {
  flex-shrink: 0;
  margin-right: 16rpx;
}

.guard-notify__icon-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD6E0 0%, #FFB3C7 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.guard-notify__icon-circle--bind {
  background: linear-gradient(135deg, #FFE0EC 0%, #FFCDD2 100%);
}

.guard-notify__icon-emoji {
  font-size: 26rpx;
  line-height: 1;
}

/* ---- 中间文字 ---- */
.guard-notify__body {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  padding: 2rpx 0;
}

.guard-notify__title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.guard-notify__desc {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-top: 2rpx;
}

/* ---- 右侧操作 ---- */
.guard-notify__actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  margin-left: 12rpx;
  gap: 8rpx;
}

.guard-notify__btn {
  padding: 10rpx 22rpx;
  background: linear-gradient(135deg, #FF7A9E 0%, #FFB3C7 100%);
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
  white-space: nowrap;
  box-shadow: 0 2rpx 8rpx rgba(255, 122, 158, 0.3);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.guard-notify__btn:active {
  transform: scale(0.95);
  box-shadow: 0 1rpx 4rpx rgba(255, 122, 158, 0.2);
}

/* 关闭按钮 */
.guard-notify__close {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.04);
  transition: background 0.15s ease;
}

.guard-notify__close:active {
  background: rgba(0, 0, 0, 0.1);
}

.guard-notify__close-icon {
  font-size: 20rpx;
  color: #BBBBBB;
  font-weight: 500;
  line-height: 1;
}
