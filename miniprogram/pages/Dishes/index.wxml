<view class="container">
  <!-- 页面头部 -->
  <view class="page-header">
    <text class="page-title">菜品库</text>
    <text class="page-subtitle">和{{partnerName}}一起管理你们的菜单 ~</text>
    <!-- 搜索框 -->
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索菜品" value="{{searchKey}}" bindinput="onSearchInput" confirm-type="search" />
      <text class="search-clear" wx:if="{{searchKey}}" bindtap="clearSearch">✕</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{dishes.length === 0 && !loading}}">
    <image class="empty-image" src="/images/dish-default.jpg" mode="aspectFit"></image>
    <text class="empty-title">菜品库空空如也</text>
    <text class="empty-desc">快添加你们喜欢的菜品吧！</text>
    <view class="btn-primary" bindtap="toAddPage">添加第一道菜</view>
  </view>

  <!-- 左右分栏布局 -->
  <view class="menu-container" wx:if="{{dishes.length > 0}}">
    <!-- 左侧分类 -->
    <scroll-view class="category-list" scroll-y scroll-with-animation scroll-into-view="{{categoryScrollId}}">
      <view class="category-item {{currentCategory === item._id ? 'active' : ''}}"
            wx:for="{{categories}}" wx:key="_id"
            id="catleft-{{item._id}}"
            data-id="{{item._id}}" bindtap="selectCategory">
        <text class="category-icon">{{item.icon}}</text>
        <text class="category-name">{{item.name}}</text>
        <text class="category-count" wx:if="{{categoryCount[item._id]}}">{{categoryCount[item._id]}}</text>
      </view>
    </scroll-view>

    <!-- 右侧菜品 -->
    <scroll-view class="dish-list" scroll-y scroll-with-animation
                 scroll-top="{{dishScrollTop}}" bindscroll="onDishScroll">
      <view wx:for="{{categories}}" wx:key="_id" wx:if="{{categoryCount[item._id] > 0}}">
        <view class="category-header" id="cat-{{item._id}}">
          <text class="category-header-icon">{{item.icon}}</text>
          <text class="category-header-name">{{item.name}}</text>
        </view>
        <view class="dish-item"
              wx:for="{{dishesByCategory[item._id]}}" wx:for-item="dish" wx:key="_id"
              data-id="{{dish._id}}" bindtap="toDetailPage" bindlongpress="showDeleteConfirm">
          <image class="dish-image" wx:if="{{dish.imageUrl}}" src="{{dish.imageUrl}}" mode="aspectFill"></image>
          <image class="dish-image" wx:else src="/images/dish-default.jpg" mode="aspectFill"></image>
          <view class="dish-info">
            <text class="dish-name">{{dish.name}}</text>
            <view class="dish-meta">
              <text class="dish-desc" wx:if="{{dish.description}}">"{{dish.description}}"</text>
              <text class="dish-count" wx:if="{{dish.orderCount > 0}}">已点{{dish.orderCount}}次</text>
            </view>
          </view>
          <view class="dish-more">
            <text>></text>
          </view>
        </view>
      </view>
      <view class="list-bottom">~ 已经到底啦 ~</view>
    </scroll-view>
  </view>

  <!-- 悬浮添加按钮 -->
  <view class="fab" bindtap="toAddPage" wx:if="{{dishes.length > 0}}">
    <text class="fab-text">+</text>
  </view>
</view>

<bind-guard />
