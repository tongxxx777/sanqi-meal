/* 菜品库样式 - 与点菜页 UI 保持一致 */

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F5F5;
}

/* 页面头部 */
.page-header {
  padding: 30rpx 24rpx 20rpx;
  background: var(--gradient-header);
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 6rpx;
}

.page-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 搜索框 */
.search-box {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  margin-top: 20rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-clear {
  font-size: 28rpx;
  color: var(--text-hint);
  padding: 0 10rpx;
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 30rpx;
}

/* 左右分栏容器 */
.menu-container {
  flex: 1;
  display: flex;
  overflow: hidden;
  -webkit-overflow-scrolling: touch;
}

/* 左侧分类 */
.category-list {
  width: 180rpx;
  background: #F8F8F8;
  height: 100%;
  will-change: scroll-position;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  position: relative;
  border-left: 6rpx solid transparent;
}

.category-item.active {
  background: white;
  border-left-color: var(--primary-color);
}

.category-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
}

.category-item.active .category-name {
  color: var(--primary-color);
  font-weight: 500;
}

.category-count {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 20rpx;
  color: white;
  background: var(--primary-color);
  border-radius: 16rpx;
  padding: 0 8rpx;
}

/* 右侧菜品 */
.dish-list {
  flex: 1;
  background: white;
  height: 100%;
  will-change: scroll-position;
}

.category-header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #FAFAFA;
}

.category-header-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.category-header-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.dish-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.dish-image {
  width: 170rpx;
  height: 170rpx;
  border-radius: 12rpx;
  background: #F5F5F5;
}

.dish-info {
  flex: 1;
  margin-left: 20rpx;
}

.dish-name {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.dish-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 10rpx;
}

.dish-count {
  font-size: 22rpx;
  color: var(--text-hint);
}

.dish-desc {
  font-size: 22rpx;
  color: var(--primary-color);
  background: var(--highlight-bg);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 右箭头指示 */
.dish-more {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #CCC;
  flex-shrink: 0;
}

.list-bottom {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #CCC;
}

/* 悬浮添加按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(80rpx + env(safe-area-inset-bottom));
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: var(--gradient-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-fab);
  z-index: 999;
}

.fab-text {
  font-size: 56rpx;
  color: white;
  font-weight: 300;
  margin-top: -4rpx;
}
