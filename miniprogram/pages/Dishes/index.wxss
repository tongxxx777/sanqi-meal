/* 菜品库样式 */

.container {
  padding-bottom: 180rpx;
}

/* 页面头部 */
.page-header {
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #6FCF97 0%, #B8E6C1 100%);
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 搜索区域 */
.search-section {
  padding: 24rpx 16rpx;
  margin-top: -20rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(124, 179, 66, 0.15);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 60rpx;
}

.empty-image {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 40rpx;
}

.empty-emoji {
  font-size: 150rpx;
  margin-bottom: 40rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.btn-primary {
  padding: 24rpx 60rpx;
  background: linear-gradient(135deg, #6FCF97 0%, #5AC476 100%);
  border-radius: 50rpx;
  font-size: 30rpx;
  color: white;
  font-weight: 500;
}

/* 菜品网格 */
.dish-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 20rpx;
}

.dish-card {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(124, 179, 66, 0.08);
}

.dish-card-image {
  width: 100%;
  height: 280rpx;
  background: #F5F9F0;
}

.dish-card-info {
  padding: 20rpx;
}

.dish-card-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-card-time {
  font-size: 22rpx;
  color: #999;
}

/* 无搜索结果 */
.no-result {
  text-align: center;
  padding: 60rpx;
}

.no-result-text {
  font-size: 28rpx;
  color: #999;
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6FCF97 0%, #5AC476 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(124, 179, 66, 0.4);
  z-index: 999;
}

.fab-text {
  font-size: 56rpx;
  color: white;
  font-weight: 300;
  margin-top: -4rpx;
}
