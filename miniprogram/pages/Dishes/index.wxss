/* 菜品库样式 - 蜜桃奶油系 */

.container { padding-bottom: 180rpx; }

/* 页面头部 */
.page-header {
  padding: 40rpx 30rpx 30rpx;
  background: var(--gradient-header);
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 搜索框 */
.search-box {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  margin-top: 20rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-clear {
  font-size: 28rpx;
  color: var(--text-hint);
  padding: 0 10rpx;
}

/* 分类标签栏 */
.category-tabs {
  padding: 16rpx 0 8rpx;
}

.tabs-scroll {
  white-space: nowrap;
  padding: 0 16rpx;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 24rpx;
  margin-right: 12rpx;
  background: white;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.tab-item.active {
  background: var(--primary-color);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(255, 122, 158, 0.3);
}

.tab-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.tab-name {
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 60rpx;
}

.empty-image {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 40rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-bottom: 40rpx;
}

.btn-primary {
  padding: 24rpx 60rpx;
  background: var(--gradient-primary);
  border-radius: 50rpx;
  font-size: 30rpx;
  color: white;
  font-weight: 500;
}

/* 菜品网格 */
.dish-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 20rpx;
}

.dish-card {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card-light);
}

.dish-card-image {
  width: 100%;
  height: 280rpx;
  background: var(--bg-color);
}

.dish-card-info { padding: 20rpx; }

.dish-card-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-card-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

/* 无搜索结果 */
.no-result {
  text-align: center;
  padding: 60rpx;
}

.no-result-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: var(--gradient-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-fab);
  z-index: 999;
}

.fab-text {
  font-size: 56rpx;
  color: white;
  font-weight: 300;
  margin-top: -4rpx;
}
