/* 添加菜品页样式 - 蜜桃奶油系 */

.container { padding-bottom: 160rpx; }

/* 页面头部 */
.page-header {
  padding: 40rpx 30rpx;
  background: var(--gradient-header);
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 表单区域 */
.form-section {
  padding: 30rpx 24rpx;
}

/* 图片上传 */
.upload-card {
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  margin-bottom: 30rpx;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  background: #FAFAFA;
  border: 4rpx dashed var(--border-color);
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: var(--text-hint);
}

.preview-image {
  width: 100%;
  height: 400rpx;
}

/* 输入卡片 */
.input-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: 30rpx;
}

.input-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.label-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.label-optional {
  font-size: 24rpx;
  color: var(--text-hint);
  font-weight: normal;
  margin-left: 8rpx;
}

.input-field {
  width: 100%;
  font-size: 32rpx;
  color: var(--text-primary);
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}

.input-placeholder { color: #CCC; }

.input-counter {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 12rpx;
}

/* 分类选择器 */
.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  font-size: 32rpx;
  color: var(--text-primary);
  border-bottom: 2rpx solid var(--border-color);
}

.picker-arrow {
  font-size: 36rpx;
  color: #CCC;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: white;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-reset {
  flex: 1;
  text-align: center;
  padding: 28rpx;
  font-size: 30rpx;
  color: var(--text-secondary);
  background: #F5F5F5;
  border-radius: 50rpx;
  margin-right: 20rpx;
}

.btn-save {
  flex: 2;
  text-align: center;
  padding: 28rpx;
  font-size: 30rpx;
  color: white;
  background: var(--gradient-primary);
  border-radius: 50rpx;
  font-weight: 500;
}
