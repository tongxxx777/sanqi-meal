/* 情侣邀请确认页 - 蜜桃奶油系 */

/* page 与导航同色渐变，彻底消灭白边 */
page { background: var(--gradient-header); }

/* 导航栏 */
.custom-nav {
  background: var(--gradient-header);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 20rpx;
}

.nav-back {
  width: 80rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: white;
  font-weight: 300;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 500;
  color: white;
}

.nav-placeholder { width: 80rpx; }

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF6F8 0%, #FFFFFF 40%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 60rpx;
  position: relative;
  overflow: hidden;
}

/* ===== 加载中 ===== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-top: 32rpx;
}

/* ===== 加载失败 ===== */
.fail-section {
  display: flex;
  flex: 1;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.fail-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: white;
  border-radius: 32rpx;
  padding: 80rpx 50rpx 60rpx;
  width: 100%;
  box-shadow: var(--shadow-card-medium);
  text-align: center;
}


.fail-emoji {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.fail-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.fail-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 50rpx;
}

.fail-card .btn-primary {
  padding: 24rpx 80rpx;
}

/* ===== 顶部装饰 ===== */
.top-decoration {
  position: absolute;
  top: -80rpx;
  right: -60rpx;
  width: 400rpx;
  height: 400rpx;
  pointer-events: none;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.08;
}

.deco-1 {
  width: 300rpx;
  height: 300rpx;
  background: var(--primary-color);
  top: 0;
  right: 0;
}

.deco-2 {
  width: 200rpx;
  height: 200rpx;
  background: var(--primary-light);
  top: 60rpx;
  right: 80rpx;
}

.deco-3 {
  width: 120rpx;
  height: 120rpx;
  background: #FFD6E0;
  top: 160rpx;
  right: 20rpx;
}

/* ===== 头部 ===== */
.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
  position: relative;
  z-index: 1;
}

.header-badge {
  font-size: 24rpx;
  color: var(--primary-color);
  background: #FFF0F4;
  padding: 8rpx 28rpx;
  border-radius: 30rpx;
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}

.header-title {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 4rpx;
}

/* ===== 邀请人信息卡片 ===== */
.inviter-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: white;
  border-radius: 32rpx;
  padding: 60rpx 50rpx 48rpx;
  margin: 50rpx 40rpx 0;
  width: calc(100% - 80rpx);
  box-sizing: border-box;
  box-shadow: var(--shadow-card-medium);
  position: relative;
  z-index: 1;
}

.avatar-frame {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 28rpx;
}

.inviter-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f5f5f5;
}

.avatar-ring {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  width: 176rpx;
  height: 176rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  border-top-color: var(--primary-color);
  border-right-color: var(--primary-light);
  animation: ringRotate 3s linear infinite;
  pointer-events: none;
}

@keyframes ringRotate {
  to { transform: rotate(360deg); }
}

.inviter-name {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 18rpx;
}

.invite-desc {
  font-size: 30rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.invite-sub {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* ===== 温馨提示 ===== */
.tips-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 30rpx 40rpx;
  margin: 36rpx 40rpx 0;
  width: calc(100% - 80rpx);
  box-sizing: border-box;
  background: linear-gradient(135deg, #FFF0F4 0%, #FFF5F7 100%);
  border-radius: 24rpx;
}

.tips-item {
  display: flex;
  align-items: flex-start;
}

.tips-dot {
  font-size: 20rpx;
  color: var(--primary-color);
  margin-right: 12rpx;
  line-height: 1.6;
  flex-shrink: 0;
}

.tips-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* ===== 按钮区 ===== */
.action-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 56rpx;
  width: calc(100% - 80rpx);
  position: relative;
  z-index: 1;
}

.accept-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100rpx;
  background: var(--gradient-primary);
  color: white;
  font-size: 36rpx;
  font-weight: 600;
  border-radius: 56rpx;
  border: none;
  box-shadow: var(--shadow-button);
  line-height: 100rpx;
  letter-spacing: 4rpx;
}

.accept-btn::after { display: none; }

.accept-btn[disabled] {
  opacity: 0.7;
}

.accept-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
  animation: heartPulse 1.5s ease-in-out infinite;
}

@keyframes heartPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}

.decline-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 28rpx;
  padding: 24rpx 60rpx;
  color: var(--text-hint);
  font-size: 28rpx;
}


