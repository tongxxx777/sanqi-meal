<view class="container" wx:if="{{order}}">
  <!-- 头部信息 -->
  <view class="header-card">
    <view class="header-row">
      <text class="header-date">{{order.dateText}}</text>
      <view class="status-tag {{order.status === 'completed' ? 'status-completed' : 'status-pending'}}">
        {{order.status === 'completed' ? '已完成' : '进行中'}}
      </view>
    </view>
    <view class="header-creator">{{order.creatorName}}点的菜</view>
    <view class="header-expect" wx:if="{{order.expectText}}">🕗 期望用餐：{{order.expectText}}</view>
  </view>

  <!-- 菜品列表 -->
  <view class="section">
    <view class="section-title">
      <text class="section-icon">🍽️</text>
      <text>菜品清单</text>
      <text class="dish-total">共{{order.dishes.length}}道</text>
    </view>
    <view class="dish-list">
      <view class="dish-item" wx:for="{{order.dishes}}" wx:key="_id">
        <image class="dish-image" wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill"></image>
        <image class="dish-image" wx:else src="/images/default.jpg" mode="aspectFill"></image>
        <text class="dish-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="section" wx:if="{{order.remark}}">
    <view class="section-title">
      <text class="section-icon">💬</text>
      <text>备注</text>
    </view>
    <view class="remark-card">
      <text class="remark-text">{{order.remark}}</text>
    </view>
  </view>

  <!-- 成品照片 -->
  <view class="section photo-section">
    <view class="section-title">
      <text class="section-icon">📸</text>
      <text>成品照片</text>
    </view>
    
    <!-- 已有照片 -->
    <view class="photo-preview" wx:if="{{order.finishedPhoto}}">
      <image class="finished-photo" src="{{order.finishedPhoto}}" mode="aspectFill" bindtap="previewPhoto"></image>
      <!-- 做菜人（非点菜人）才能操作照片 -->
      <view class="photo-actions" wx:if="{{!isCreator}}">
        <view class="photo-action-btn" bindtap="changePhoto">
          <text class="action-icon">🔄</text>
          <text>更换照片</text>
        </view>
        <view class="photo-action-btn delete" bindtap="deletePhoto">
          <text class="action-icon">🗑️</text>
          <text>删除</text>
        </view>
      </view>
      <!-- 点菜人查看提示 -->
      <view class="photo-viewer-hint" wx:if="{{isCreator}}">
        <text class="viewer-text">等待大厨上传成品照片 📷</text>
      </view>
    </view>
    
    <!-- 未上传照片 -->
    <!-- 做菜人（非点菜人）才能上传 -->
    <view class="photo-upload" wx:if="{{!order.finishedPhoto && !isCreator}}" bindtap="uploadPhoto">
      <view class="upload-icon">📷</view>
      <text class="upload-text">拍一张做好的菜</text>
      <text class="upload-hint">点击上传照片</text>
    </view>
    <!-- 点菜人等待提示 -->
    <view class="photo-waiting" wx:if="{{!order.finishedPhoto && isCreator}}">
      <text class="waiting-icon">⏳</text>
      <text class="waiting-text">等待大厨上传成品照片</text>
    </view>
  </view>

  <!-- 底部操作区域 -->
  <!-- 做菜人（非点菜人）才能标记完成 -->
  <view class="complete-btn" wx:if="{{order.status !== 'completed' && !isCreator}}" bindtap="markAsCompleted">
    <text>确认完成</text>
  </view>
  <!-- 点菜人等待提示 -->
  <view class="waiting-complete" wx:if="{{order.status !== 'completed' && isCreator}}">
    <text class="waiting-icon">⏳</text>
    <text class="waiting-text">等待大厨确认完成...</text>
  </view>
</view>

<!-- 加载中 -->
<view class="loading" wx:if="{{loading}}">
  <text>加载中...</text>
</view>
<bind-guard />
