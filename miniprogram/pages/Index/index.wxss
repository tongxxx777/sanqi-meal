/* 首页样式 - 蜜桃奶油系 */

/* 页面加载状态 */
.page-loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, var(--border-color) 0%, #F5F5F5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 40rpx;
}

.loading-dots-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--primary-color);
  border-radius: 50%;
  animation: dotBounce 1.4s ease-in-out infinite;
}

.loading-dot:nth-child(1) { animation-delay: 0s; }
.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(1); opacity: 0.6; }
  40% { transform: scale(1.4); opacity: 1; }
}

.container {
  padding: 0;
  padding-bottom: 180rpx;
}

/* 欢迎区域 */
.welcome-section {
  width: 100%;
  background: var(--gradient-header);
  padding: 60rpx 40rpx 80rpx;
  border-radius: 0 0 60rpx 60rpx;
}

.welcome-card {
  display: flex;
  align-items: center;
}

.avatar-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: white;
  margin-right: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}


.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  border-radius: 20rpx;
}

.welcome-text {
  display: flex;
  flex-direction: column;
}

.greeting {
  font-size: 40rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 8rpx;
}

.sub-greeting {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 通用区域标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin: 40rpx 16rpx 20rpx;
}

/* 今日状态 */
.status-section {
  margin-top: 0;
  padding: 0 16rpx;
}

.status-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: var(--shadow-card-medium);
}

.status-card + .status-card {
  margin-top: 20rpx;
}

.status-label-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.status-tag-mini {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.status-tag-mini.status-pending {
  background: #FFF3E0;
  color: #FF9800;
}

.status-tag-mini.status-completed {
  background: #E8F5E9;
  color: #4CAF50;
}

.completed-hint {
  color: #4CAF50;
  font-weight: 500;
}

.status-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.status-label {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.status-time {
  font-size: 26rpx;
  color: var(--text-hint);
}

.status-dishes {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.dish-tag {
  background: var(--border-color);
  color: var(--primary-color);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.photo-hint {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #B8B8B8;
}

.empty-card {
  background: white;
  border-radius: 24rpx;
  padding: 60rpx 30rpx;
  box-shadow: var(--shadow-card-medium);
  display: flex;
  flex-direction: column;
  align-items: center;
}


.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-bottom: 30rpx;
}

.btn-primary {
  padding: 20rpx 50rpx;
  background: var(--gradient-primary);
  border-radius: 50rpx;
  font-size: 28rpx;
  color: white;
  font-weight: 500;
}

/* 快捷操作 */
.quick-section { padding: 0 16rpx; }

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  background: white;
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  box-shadow: var(--shadow-card);
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quick-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.quick-icon-green { background: var(--border-color); }
.quick-icon-pink { background: #FFE8EE; }
.quick-icon-purple { background: #FFE8EE; }
.quick-icon-orange { background: #FFF3E0; }

.quick-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 统计区域 */
.stats-section { padding: 0 16rpx; }

.stats-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: var(--shadow-card);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-hint);
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: var(--border-color);
}

/* 底部装饰 */
.footer-decoration {
  padding: 60rpx 30rpx;
  text-align: center;
}

.footer-content {
  display: flex;
  align-items: center;
  justify-content: center;
}


.footer-text {
  font-size: 26rpx;
  color: var(--primary-light);
}

/* 顶部情侣模式 */
.welcome-section.couple-mode {
  background: linear-gradient(180deg, var(--primary-light) 0%, #FFE0EC 100%);
  padding: 60rpx 0 50rpx 0;
}

.couple-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-sizing: border-box;
}

.couple-greeting {
  font-size: 32rpx;
  color: var(--primary-deep);
  font-weight: 500;
  margin-bottom: 30rpx;
}

.couple-avatars-top {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 40rpx;
  box-sizing: border-box;
}

.couple-avatar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 120rpx;
}

.couple-avatar-img {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 5rpx solid var(--primary-color);
  box-shadow: 0 6rpx 20rpx rgba(255, 122, 158, 0.2);
  background: #f5f5f5;
}

.couple-avatar-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.couple-heart-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100rpx;
  padding-top: 15rpx;
}

.couple-heart-beat {
  font-size: 44rpx;
  animation: heartbeat 1.2s ease-in-out infinite;
}

@keyframes heartbeat {
  0% { transform: scale(1); }
  15% { transform: scale(1.25); }
  30% { transform: scale(1); }
  45% { transform: scale(1.2); }
  60% { transform: scale(1); }
  100% { transform: scale(1); }
}

.couple-days {
  font-size: 20rpx;
  color: white;
  margin-top: 4rpx;
  background: var(--primary-color);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

/* 绑定提示 */
.bind-tip-section {
  padding: 30rpx 16rpx 0;
}

.bind-tip-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFE0EC 0%, #FFCDD2 100%);
  border-radius: 24rpx;
  padding: 30rpx;
}

.bind-tip-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.bind-tip-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.bind-tip-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--primary-deep);
  margin-bottom: 4rpx;
}

.bind-tip-desc {
  font-size: 24rpx;
  color: var(--primary-color);
}

.bind-tip-arrow {
  font-size: 32rpx;
  color: var(--primary-color);
}

/* profile 提醒卡片 */
.profile-tip-card {
  background: linear-gradient(135deg, var(--border-color) 0%, var(--primary-light) 100%);
}

.profile-tip-card .bind-tip-title {
  color: var(--primary-deep);
}

.profile-tip-card .bind-tip-desc {
  color: var(--primary-color);
}

.profile-tip-card .bind-tip-arrow {
  color: var(--primary-color);
}

/* 订阅提醒卡片 */
.subscribe-tip-card {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.subscribe-tip-card .bind-tip-title {
  color: #2E7D32;
}

.subscribe-tip-card .bind-tip-desc {
  color: #66BB6A;
}

.subscribe-tip-card .bind-tip-arrow {
  color: #66BB6A;
}
