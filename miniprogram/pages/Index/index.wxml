<!-- 页面加载中 -->
<view class="page-loading" wx:if="{{pageLoading}}">
  <view class="loading-content">
    <image class="loading-image" src="/images/1.gif" mode="aspectFit"></image>
    <view class="loading-dots-wrap">
      <view class="loading-dot"></view>
      <view class="loading-dot"></view>
      <view class="loading-dot"></view>
    </view>
  </view>
</view>

<view class="container" wx:else>
  <!-- 顶部区域：已绑定显示情侣卡片，未绑定显示欢迎卡片 -->
  <view class="welcome-section {{isBound ? 'couple-mode' : ''}}">
    <!-- 未绑定：原欢迎卡片 -->
    <view wx:if="{{!isBound}}" class="welcome-card">
      <image class="avatar-image" src="{{userAvatar || '/images/user-default.jpg'}}" mode="aspectFill" bindtap="goToSettings"></image>
      <view class="welcome-text">
        <text class="greeting">{{greeting}}，{{userName || '新朋友'}}！</text>
        <text class="sub-greeting">今天想吃点什么呀？</text>
      </view>
    </view>
    <!-- 已绑定：情侣卡片 -->
    <view wx:else class="couple-header" bindtap="goToBind">
      <view class="couple-greeting">{{greeting}}，一起吃点什么？</view>
      <view class="couple-avatars-top">
        <view class="couple-avatar-item" catchtap="goToSettings">
          <image class="couple-avatar-img" src="{{userAvatar || '/images/user-default.jpg'}}" mode="aspectFill"></image>
          <text class="couple-avatar-name">{{userName}}</text>
        </view>
        <view class="couple-heart-center">
          <view class="couple-heart-beat">❤️</view>
          <text class="couple-days" wx:if="{{bindDays > 0}}">{{bindDays}}天</text>
        </view>
        <view class="couple-avatar-item">
          <image class="couple-avatar-img" src="{{partnerAvatar || '/images/user-default.jpg'}}" mode="aspectFill"></image>
          <text class="couple-avatar-name">{{partnerName}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- profile 未完成提醒卡片 -->
  <view wx:if="{{!profileComplete}}" class="bind-tip-section">
    <view class="bind-tip-card profile-tip-card" bindtap="goToSetProfile">
      <text class="bind-tip-icon">🥺</text>
      <view class="bind-tip-content">
        <text class="bind-tip-title">还没有设置头像和昵称</text>
        <text class="bind-tip-desc">点击设置，做个有身份的人儿~</text>
      </view>
    </view>
  </view>

  <!-- 未绑定提示 -->
  <view wx:if="{{!isBound}}" class="bind-tip-section">
    <view class="bind-tip-card" bindtap="goToBind">
      <text class="bind-tip-icon">💕</text>
      <view class="bind-tip-content">
        <text class="bind-tip-title">还没有绑定另一半</text>
        <text class="bind-tip-desc">点击邀请 TA 入驻你的小厨房</text>
      </view>

    </view>
  </view>

  <!-- 订阅消息提醒 -->
  <view wx:if="{{!subscribeRequested}}" class="bind-tip-section">
    <view class="bind-tip-card subscribe-tip-card" bindtap="goToSubscribe">
      <text class="bind-tip-icon">🔔</text>
      <view class="bind-tip-content">
        <text class="bind-tip-title">开启点菜提醒通知</text>
        <text class="bind-tip-desc">TA 点菜时你会收到提醒哦~</text>
      </view>
      <text class="bind-tip-arrow">›</text>
    </view>
  </view>

  <!-- 今日状态卡片 -->
  <view class="status-section" wx:if="{{isBound}}">
    <view class="section-title">🍽️ 今日点菜</view>
    <view class="status-card" wx:if="{{todayOrder}}" bindtap="goToTodayOrder">
      <view class="status-header">
        <text class="status-label">{{todayOrder.creatorName}} 点了菜</text>
        <text class="status-time">{{todayOrder.timeText}}</text>
      </view>
      <view class="status-dishes">
        <view class="dish-tag" wx:for="{{todayOrder.dishes}}" wx:key="index">
          {{item.name}}
        </view>
      </view>
      <view class="photo-hint" wx:if="{{!todayOrder.finishedPhoto}}">
        <text>📷 做好了记得拍一张~</text>
      </view>
    </view>
    <view class="empty-card" wx:else>
      <image class="empty-image" src="/images/2.gif" mode="aspectFit"></image>
      <text class="empty-text">今天还没有点菜哦~</text>
      <view class="btn-primary" bindtap="goToOrder">去点菜</view>
    </view>
  </view>


  <!-- 快捷入口 -->
  <view class="quick-section">
    <view class="section-title">⚡ 快捷操作</view>
    <view class="quick-grid">
      <view class="quick-item" bindtap="goToSettings">
        <view class="quick-icon quick-icon-green">😊</view>
        <text class="quick-label">个人中心</text>
      </view>
      <view class="quick-item" bindtap="goToBind">
        <view class="quick-icon quick-icon-pink">💕</view>
        <text class="quick-label">绑定关系</text>
      </view>
      <view class="quick-item" bindtap="goToCategoryManage">
        <view class="quick-icon quick-icon-purple">🍽️</view>
        <text class="quick-label">类目管理</text>
      </view>
      <view class="quick-item" bindtap="goToRecentOrder">
        <view class="quick-icon quick-icon-orange">🕐</view>
        <text class="quick-label">最近点菜</text>
      </view>
    </view>
  </view>

  <!-- 菜品统计 -->
  <view class="stats-section" wx:if="{{isBound}}">
    <view class="section-title">📊 小厨房统计</view>
    <view class="stats-card">
      <view class="stat-item">
        <text class="stat-number">{{dishCount}}</text>
        <text class="stat-label">菜品总数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-number">{{orderCount}}</text>
        <text class="stat-label">点菜次数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-number">{{togetherDays}}</text>
        <text class="stat-label">一起吃饭</text>
      </view>
    </view>
  </view>
  <!-- 底部装饰 -->
  <view class="footer-decoration">
    <view class="footer-content">
          <text class="footer-text">Made with love 🎀 shared with you</text>
    </view>
  </view>
</view>
