/* 历史页样式 - 蜜桃奶油系 */

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F5F5;
  overflow: hidden;
}

/* 页面头部 */
.page-header {
  padding: 30rpx 24rpx 20rpx;
  background: var(--gradient-header);
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 6rpx;
}

.page-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 可滚动内容区 */
.content-scroll {
  flex: 1;
  height: 0;
  -webkit-overflow-scrolling: touch;
}

/* 历史列表 */
.history-list { padding: 24rpx 16rpx; }

.history-item {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: var(--shadow-card);
}

.history-item-wrapper {
  margin-bottom: 32rpx;
}

.delete-btn,
mp-slideview .delete-btn,
.weui-slideview__btn.delete-btn {
  background-color: #E57373 !important;
}

.mark-btn,
mp-slideview .mark-btn,
.weui-slideview__btn.mark-btn {
  background-color: #FFB74D !important;
}

/* 标记高亮 */
.history-item.marked {
  background: linear-gradient(135deg, var(--highlight-bg) 0%, var(--primary-light) 100%);
  border: 2rpx solid var(--primary-dark);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.history-date { display: flex; align-items: center; }

.date-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.date-text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.history-time {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 菜品列表 */
.history-dishes {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.history-dish {
  display: flex;
  align-items: center;
  background: var(--bg-color);
  border-radius: 40rpx;
  padding: 8rpx 24rpx 8rpx 8rpx;
}

.history-dish-image {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}


.history-dish-name {
  font-size: 26rpx;
  color: var(--primary-color);
}

/* 备注 */
.history-remark {
  display: flex;
  align-items: center;
  background: #FFF5F2;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}

.remark-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.remark-text {
  font-size: 26rpx;
  color: var(--primary-deep);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  word-break: break-all;
}

/* 底部信息 */
.history-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--bg-color);
}

.history-creator {
  font-size: 26rpx;
  color: var(--text-hint);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.dish-count {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
  flex-shrink: 0;
}

.history-footer-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.status-tag-mini {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.status-tag-mini.status-pending {
  background: #FFF3E0;
  color: #FF9800;
}

.status-tag-mini.status-completed {
  background: #E8F5E9;
  color: #4CAF50;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
}

.load-more text {
  font-size: 28rpx;
  color: var(--primary-color);
}

/* 没有更多 */
.no-more {
  text-align: center;
  padding: 30rpx;
}

.no-more text {
  font-size: 26rpx;
  color: #CCC;
}

/* 提示弹窗 */
.tip-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.tip-content {
  background: white;
  border-radius: 32rpx;
  padding: 50rpx 40rpx;
  width: 500rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: tipPop 0.3s ease-out;
}

@keyframes tipPop {
  from { transform: scale(0.8); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.tip-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.tip-text {
  font-size: 30rpx;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.tip-btn {
  background: var(--gradient-header);
  color: white;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  box-shadow: var(--shadow-button);
}
