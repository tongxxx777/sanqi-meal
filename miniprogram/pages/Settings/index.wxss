/* 设置页样式 - 蜜桃奶油系 */

.container {
  padding-bottom: 60rpx;
  background: var(--bg-color);
  min-height: 100vh;
}

/* 页面头部 */
.page-header {
  display: flex;
  align-items: center;
  padding: 60rpx 40rpx;
  background: var(--gradient-header);
}

.header-mascot {
  width: 120rpx;
  height: 120rpx;
  margin-right: 30rpx;
  border-radius: 50%;
  background: white;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}


.header-info {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 设置分组 */
.settings-section {
  padding: 30rpx 24rpx 0;
}

.section-title {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.settings-card {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card-light);
}

.settings-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 2rpx solid var(--bg-color);
}

.settings-item:last-child { border-bottom: none; }

.item-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.item-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: var(--bg-color);
}

.item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 32rpx;
  color: var(--primary-color);
  font-weight: 500;
}

.item-label {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
}

.item-right {
  display: flex;
  align-items: center;
}

.partner-mini-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  background: var(--bg-color);
}

.item-value {
  font-size: 28rpx;
  color: var(--primary-color);
}

.item-value.unbound {
  color: var(--text-hint);
}

.item-arrow {
  font-size: 28rpx;
  color: #CCC;
  margin-left: 10rpx;
}

/* 底部版权 */
.footer {
  padding: 60rpx 0;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* ========================================
   头像昵称编辑 —— 居中弹窗
   ======================================== */

/* 遮罩层 */
.sheet-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.45);
  transition: opacity 0.3s ease;
}

.sheet-overlay--hidden {
  opacity: 0;
  pointer-events: none;
}

/* 弹窗面板 */
.sheet-panel {
  width: 90%;
  max-width: 600rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  transform: scale(1);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.18);
  padding: 0 0 24rpx;
}

.sheet-panel--hidden {
  transform: scale(0.9);
  opacity: 0;
}

/* 拖拽手柄 - 隐藏 */
.sheet-handle {
  display: none;
}

/* 标题区 */
.sheet-header {
  padding: 48rpx 40rpx 8rpx;
  text-align: center;
}

.sheet-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 10rpx;
}

.sheet-desc {
  display: block;
  font-size: 26rpx;
  color: #999999;
}

/* 内容区 */
.sheet-body {
  padding: 24rpx 48rpx 0;
}

/* ---- 头像选择 ---- */
.avatar-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
}

.avatar-pick-btn {
  width: 152rpx;
  height: 152rpx;
  padding: 0;
  margin: 0 0 20rpx;
  background: transparent;
  border: none;
  line-height: normal;
}

.avatar-pick-btn::after { display: none; }

.avatar-pick-img {
  width: 152rpx;
  height: 152rpx;
  border-radius: 50%;
  background: var(--bg-color);
  border: 5rpx solid var(--primary-light);
  box-sizing: border-box;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 148, 0.15);
}

.avatar-hint {
  font-size: 24rpx;
  color: #B0B0B0;
}

/* ---- 昵称输入 ---- */
.nick-area {
  display: flex;
  flex-direction: column;
}

.nick-label {
  font-size: 28rpx;
  color: #555555;
  margin-bottom: 14rpx;
  font-weight: 500;
}

.nick-input-wrap { position: relative; }

.nick-input {
  width: 100%;
  height: 88rpx;
  background: #FFF6F8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.2s ease, background 0.2s ease;
}

.nick-input:focus {
  border-color: var(--primary-light);
  background: #FFF0F4;
}

.nick-hint {
  display: flex;
  align-items: center;
  margin-top: 14rpx;
  padding: 10rpx 16rpx;
  background: linear-gradient(135deg, #FFF0F4 0%, #FFE8EE 100%);
  border-radius: 10rpx;
}

.nick-hint__icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.nick-hint__text {
  font-size: 22rpx;
  color: #E87A90;
  line-height: 1.4;
}

/* ---- 底部按钮 ---- */
.sheet-footer {
  display: flex;
  padding: 36rpx 48rpx 0;
  gap: 20rpx;
}

.sheet-btn {
  flex: 1;
  height: 84rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 42rpx;
  transition: transform 0.15s ease, opacity 0.15s ease;
}

.sheet-btn:active {
  transform: scale(0.96);
}

.sheet-btn--cancel {
  background: #F5F5F5;
  color: #888888;
}

.sheet-btn--cancel:active {
  background: #EBEBEB;
}

.sheet-btn--save {
  background: var(--gradient-primary);
  color: white;
  box-shadow: 0 4rpx 18rpx rgba(255, 107, 148, 0.3);
}

.sheet-btn--loading {
  opacity: 0.7;
  pointer-events: none;
}