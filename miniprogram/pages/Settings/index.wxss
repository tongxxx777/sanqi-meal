/* 设置页样式 */

.container {
  padding-bottom: 60rpx;
  background: #F5F9F0;
  min-height: 100vh;
}

/* 页面头部 */
.page-header {
  display: flex;
  align-items: center;
  padding: 60rpx 40rpx;
  background: linear-gradient(135deg, #6FCF97 0%, #B8E6C1 100%);
}

.header-mascot {
  width: 120rpx;
  height: 120rpx;
  margin-right: 30rpx;
  border-radius: 50%;
  background: white;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.emoji-mascot {
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.header-info {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 设置分组 */
.settings-section {
  padding: 30rpx 24rpx 0;
}

.section-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.settings-card {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(124, 179, 66, 0.08);
}

.settings-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 2rpx solid #F5F9F0;
}

.settings-item:last-child {
  border-bottom: none;
}

.item-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.item-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #F5F9F0;
}

.item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 32rpx;
  color: #6FCF97;
  font-weight: 500;
}

.item-label {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.item-right {
  display: flex;
  align-items: center;
}

.partner-mini-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  background: #F5F9F0;
}

.item-value {
  font-size: 28rpx;
  color: #6FCF97;
}

.item-value.unbound {
  color: #999;
}

.item-arrow {
  font-size: 28rpx;
  color: #CCC;
  margin-left: 10rpx;
}

/* 底部版权 */
.footer {
  padding: 60rpx 0;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
}

/* 客服按钮：强制重置 button 默认样式 */
.contact-btn {
  display: flex !important;
  align-items: center !important;
  width: 100% !important;
  padding: 30rpx 24rpx !important;
  margin: 0 !important;
  background: transparent !important;
  border: none !important;
  border-radius: 0 !important;
  line-height: normal !important;
  text-align: left !important;
  box-sizing: border-box !important;
  font-size: inherit !important;
  color: inherit !important;
  min-height: 0 !important;
}

.contact-btn::after {
  display: none !important;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  width: 640rpx;
  background: white;
  border-radius: 32rpx;
  overflow: hidden;
}

.modal-header {
  padding: 40rpx;
  text-align: center;
  background: linear-gradient(135deg, #6FCF97 0%, #B8E6C1 100%);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: white;
}

.modal-body {
  padding: 40rpx;
}

/* 头像选择区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar-btn {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: normal;
}

.avatar-btn::after {
  display: none;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #F5F9F0;
}

.avatar-edit-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 48rpx;
  height: 48rpx;
  background: #6FCF97;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
  border: 4rpx solid white;
}

.avatar-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 昵称输入区域 */
.nickname-section {
  display: flex;
  flex-direction: column;
}

.nickname-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.nickname-input-wrap {
  position: relative;
}

.nickname-input {
  width: 100%;
  height: 90rpx;
  background: #F5F9F0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
}

.nickname-tip {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border-radius: 12rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #689F38;
}

.modal-footer {
  display: flex;
  padding: 0 40rpx 40rpx;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 30rpx;
  border-radius: 44rpx;
}

.modal-btn.cancel {
  background: #F5F5F5;
  color: #666;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #6FCF97 0%, #6FCF97 100%);
  color: white;
  font-weight: 500;
}
