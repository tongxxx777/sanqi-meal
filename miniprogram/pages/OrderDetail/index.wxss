.container {
  padding: 24rpx;
  min-height: 100vh;
  background: #F5F9F0;
}

/* 头部卡片 */
.header-card {
  background: linear-gradient(135deg, #6FCF97 0%, #B8E6C1 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.header-date {
  font-size: 36rpx;
  font-weight: 600;
  color: white;
}

.header-time {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.header-creator {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 区块 */
.section {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(124, 179, 66, 0.1);
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 24rpx;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.dish-total {
  margin-left: auto;
  font-size: 26rpx;
  color: #6FCF97;
  font-weight: normal;
}

/* 菜品列表 */
.dish-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dish-item {
  display: flex;
  align-items: center;
  background: #F5F9F0;
  border-radius: 16rpx;
  padding: 16rpx;
}

.dish-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: #E8F5E9;
}

.dish-name {
  flex: 1;
  margin-left: 20rpx;
  font-size: 30rpx;
  color: #333;
}

/* 备注 */
.remark-card {
  background: #FFF9E6;
  border-radius: 16rpx;
  padding: 24rpx;
}

.remark-text {
  font-size: 28rpx;
  color: #996600;
  line-height: 1.6;
}

/* 再来一单按钮 */
.reorder-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #6FCF97 0%, #5AC476 100%);
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  padding: 28rpx;
  border-radius: 50rpx;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(124, 179, 66, 0.3);
}

.reorder-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

/* 成品照片 */
.photo-section .section-title {
  position: relative;
}

.photo-tip {
  margin-left: auto;
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
}

.photo-upload {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 30rpx;
  background: #F5F9F0;
  border-radius: 16rpx;
  border: 2rpx dashed #B8E6C1;
}

.upload-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #999;
}

.photo-preview {
  display: flex;
  flex-direction: column;
}

.finished-photo {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  display: block;
}

.photo-actions {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 24rpx;
}

.photo-action-btn {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
  padding: 16rpx 24rpx;
  background: #F5F5F5;
  border-radius: 30rpx;
}

.photo-action-btn .action-icon {
  margin-right: 8rpx;
}

.photo-action-btn.delete {
  color: #E57373;
  background: #FFF5F5;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
  color: #999;
  font-size: 28rpx;
}
