/* 历史页样式 */

.container {
  padding-bottom: 60rpx;
}

/* 页面头部 */
.page-header {
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #6FCF97 0%, #B8E6C1 100%);
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 60rpx;
}

.empty-image {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 40rpx;
}

.empty-emoji {
  font-size: 150rpx;
  margin-bottom: 40rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
}

/* 历史列表 */
.history-list {
  padding: 24rpx 16rpx;
}

.history-item {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(124, 179, 66, 0.1);
}

mp-slideview {
  margin-bottom: 24rpx;
}

.delete-btn,
mp-slideview .delete-btn,
.weui-slideview__btn.delete-btn {
  background-color: #E57373 !important;
}

.mark-btn,
mp-slideview .mark-btn,
.weui-slideview__btn.mark-btn {
  background-color: #42A5F5 !important;
}

/* 标记高亮 */
.history-item.marked {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
  border: 2rpx solid #FFD54F;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.history-date {
  display: flex;
  align-items: center;
}

.date-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.date-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.history-time {
  font-size: 26rpx;
  color: #999;
}

/* 菜品列表 */
.history-dishes {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.history-dish {
  display: flex;
  align-items: center;
  background: #F5F9F0;
  border-radius: 40rpx;
  padding: 8rpx 24rpx 8rpx 8rpx;
}

.history-dish-image {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.history-dish-image.dish-emoji {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  background: white;
}

.history-dish-name {
  font-size: 26rpx;
  color: #5AC476;
}

/* 备注 */
.history-remark {
  display: flex;
  align-items: center;
  background: #FFF9E6;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}

.remark-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.remark-text {
  font-size: 26rpx;
  color: #996600;
}

/* 底部信息 */
.history-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 2rpx solid #F5F9F0;
}

.history-creator {
  font-size: 26rpx;
  color: #999;
}

.dish-count {
  font-size: 26rpx;
  color: #6FCF97;
  font-weight: 500;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
}

.load-more text {
  font-size: 28rpx;
  color: #6FCF97;
}

/* 没有更多 */
.no-more {
  text-align: center;
  padding: 30rpx;
}

.no-more text {
  font-size: 26rpx;
  color: #CCC;
}

/* 提示弹窗 */
.tip-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.tip-content {
  background: white;
  border-radius: 32rpx;
  padding: 50rpx 40rpx;
  width: 500rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: tipPop 0.3s ease-out;
}

@keyframes tipPop {
  from {
    transform: scale(0.8);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.tip-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.tip-text {
  font-size: 30rpx;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.tip-btn {
  background: linear-gradient(135deg, #6FCF97 0%, #B8E6C1 100%);
  color: white;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  box-shadow: 0 6rpx 20rpx rgba(124, 179, 66, 0.3);
}
